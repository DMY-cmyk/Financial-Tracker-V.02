# Financial Tracker — Environment Variables
# Copy this file to .env.local and fill in values as needed.

# ── App Config ──────────────────────────────────────────────
# Base URL for GitHub Pages deployment (leave empty for root)
NEXT_PUBLIC_BASE_PATH=

# App title override (optional)
NEXT_PUBLIC_APP_TITLE=Financial Tracker

# ── API Config (future) ────────────────────────────────────
# Backend API base URL (not used yet — app is fully client-side)
# NEXT_PUBLIC_API_URL=https://api.example.com

# ── Analytics (future) ─────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Feature Flags (future) ─────────────────────────────────
# NEXT_PUBLIC_ENABLE_OCR=true
# NEXT_PUBLIC_ENABLE_IMPORT=true
